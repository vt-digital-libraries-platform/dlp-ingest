commands:
  00_create_dir:
    command: mkdir -p /var/log
  01_change_permissions:
    command: chmod g+s /var/log
  02_change_owner:
    command: chown webapp:webapp /var/log

files:
  "/opt/elasticbeanstalk/tasks/taillogs.d/application.conf" :
    mode: "000755"
    owner: root
    group: root
    content: |
      /var/log/application.log